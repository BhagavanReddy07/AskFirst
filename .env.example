# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: openai | claude | groq | gemini
LLM_PROVIDER=gemini

# Google AI Studio API key — get free at: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_key_here

# Model — free tier models:
#   gemini-1.5-flash      (fast, free, recommended)
#   gemini-1.5-pro        (smarter, free with limits)
#   gemini-2.0-flash      (latest fast model)
LLM_MODEL=gemini-1.5-flash
